# file opened: CORE32.ASM
   1++C000              ; CORE32 — осмысленный exact-исходник WildDOSFileCore #35.
   2++C000              ; Физический диапазон в boot.$C: #C000..#DBD2.
   3++C000              ; LC000 копирует #C00C..#DBD2 в рабочий диапазон #4000..#5BC6.
   4++C000              ; Основные процедуры рабочего образа:
   5++C000              ;   START #4000 — 31-элементная таблица API;
   6++C000              ;   NXTETY2 #4067 и NXTETY #4140 — перечисление каталога;
   7++C000              ;   LOAD512 #43BF / SAVE512 #43AD — потоковый обмен;
   8++C000              ;   CURIT #44C5 — загрузка записи FAT;
   9++C000              ;   GIPAG #450F — позиционирование на первом секторе кластера;
  10++C000              ;   MKSG #48A6 — создание FAT-цепочки; DLSG #49E1 — удаление цепочки;
  11++C000              ;   SRHDRN #4A63 — поиск записи; MKFILE #4D52 / MKDIR #4D78 — создание;
  12++C000              ;   DELFL #4CF8 / RENAME #4D31 — удаление и переименование;
  13++C000              ;   HDD #4EA2 — поиск раздела и проверка FAT32;
  14++C000              ;   DOS_SWP #503B — выбор, распаковка и запуск драйвера;
  15++C000              ;   DEHR #5AAA — распаковщик драйверов.
  16++C000              ; ALASM-конструкция .N повторяет всю цепочку команд строки. Здесь она явно
  17++C000              ; выражена DUP/EDUP; это устраняет прежнюю потерю #50 байт и ошибки алгоритмов.
  18++C000              ; Четыре слова итератора каталога находятся по #37F8..#37FE перед драйвером,
  19++C000              ; поэтому загрузка нового драйвера в #3800 их не уничтожает.
  20++C000                      ORG #C000
  21++C000
  22++C000              LC000:
  23++C000 21 0C C0 11          LD HL,CORE32,DE,#4000
  23++C004 00 40
  24++C006 01 C7 1B             LD BC,END-START
  25++C009 ED B0                LDIR
  26++C00B C9                   RET
  27++C00C
