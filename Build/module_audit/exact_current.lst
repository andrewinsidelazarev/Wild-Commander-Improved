# file opened: WCVLS.ASM
   1++7EA0              ; WCVLS — структуры состояния Wild Commander, описатели окон и текстовые данные.
   2++7EA0              ; Exact-диапазон: #7EA0..#8530. При сборке с базой #7EA0 файл побайтно совпадает
   3++7EA0              ; с поставляемым boot.$C: 1681 байт, различий нет.
   4++7EA0              ; Основные структуры:
   5++7EA0              ;   WINDOW/WINDO2 — 36-байтовые описатели левой и правой панелей;
   6++7EA0              ;   PALLIT — таблица сочетаний страниц/палитры;
   7++7EA0              ;   PPFR..PHEP — состояние загрузчика и активного плагина;
   8++7EA0              ;   BRRR..ERRR — кластеры, размер и сохранённые каталоги файловых операций;
   9++7EA0              ;   INTPL/INTTM/INTPS — флаги обработчиков прерывания;
  10++7EA0              ;   ENTRY — текущая 32-байтовая запись каталога;
  11++7EA0              ;   ERWND/PBWND/MDWND/F5WND/HPWND/F11WND — описатели диалоговых окон.
  12++7EA0              ; Поля 36-байтового описателя панели:
  13++7EA0              ;   +0 тип, +1 маска курсора, +2/+3 X/Y, +4/+5 ширина/высота,
  14++7EA0              ;   +6 цвет, +8 адрес буфера, +10 число строк, +12/+13 курсор и максимум,
  15++7EA0              ;   +14/+15 цвета курсора, +16 верх списка, +18 число записей,
  16++7EA0              ;   +20/+21 признаки конца/начала, +22 страница, +23 смещение,
  17++7EA0              ;   +25 начальная и +26 текущая страница каталога, +27 страница драйвера,
  18++7EA0              ;   +28 флаг активации, +29 устройство, +30 начало, +32 текущий указатель,
  19++7EA0              ;   +34 флаг инициализации, +35 критерий сортировки.
  20++7EA0              ; Значения ниже раньше приходили из MD20.ASM. Условия сохраняют совместимость
  21++7EA0              ; как с отдельной exact-сборкой, так и с историческим верхнеуровневым файлом.
  22++7EA0                      IFNDEF CURmsk
  23++7EA0              CURmsk  EQU %00000111
  24++7EA0                      ENDIF
