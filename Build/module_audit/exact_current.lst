# file opened: KERNEL.ASM
   1++C00C              ; KERNEL — рабочая карта памяти и таблица API WildDOSFileCore.
   2++C00C              ; Метка CORE32 ставится физически по #C00C до DISP #4000; START и весь код
   3++C00C              ; после неё адресуются так, как исполняются после копирования.
   4++C00C              ; Ключевые области:
   5++C00C              ;   #0000..#1FFF — буфер перечисления каталога;
   6++C00C              ;   #3000..#31FF — сектор FAT; #3200/#3400 — два секторных буфера;
   7++C00C              ;   #37F8..#37FE — состояние итератора каталога;
   8++C00C              ;   #3800 — таблица входов текущего драйвера;
   9++C00C              ;   #3848 — общие переменные; #3868 — 32-байтовая FAT-запись;
  10++C00C              ;   #3889..#38CC — параметры FAT32, потоков и текущего каталога.
  11++C00C              CORE32:
  12++C00C                      DISP #4000
  13++4000              GENBU   EQU #0000
  14++4000              GENBE   EQU #2000
