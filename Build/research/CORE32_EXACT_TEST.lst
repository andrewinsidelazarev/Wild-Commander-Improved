# file opened: DEHR2.ASM
   1+ 5AAA              ; DEHR2 — распаковщик драйверов WildDOS из Hrust-подобного контейнера.
   2+ 5AAA              ; Физический адрес в boot.$C: #DAB6; рабочий адрес после копирования: #5AAA.
   3+ 5AAA              ;
   4+ 5AAA              ; Основные этапы:
   5+ 5AAA              ;   DEHR_UNPACK_DRIVER          — прочитать размеры и подготовить размещение;
   6+ 5AAA              ;   DEHR_MOVE_OVERLAPPED_STREAM — безопасно перенести перекрывающийся поток;
   7+ 5AAA              ;   DEHR_SAVE_LAST_6_BYTES      — сохранить хвост результата из заголовка;
   8+ 5AAA              ;   DEHR_TOKEN_LOOP             — основной цикл литералов и LZ-совпадений;
   9+ 5AAA              ;   DEHR_DECODE_MATCH_LENGTH    — декодировать длину совпадения;
  10+ 5AAA              ;   DEHR_DECODE_MATCH_OFFSET    — декодировать отрицательное смещение;
  11+ 5AAA              ;   DEHR_COPY_MATCH             — скопировать ранее распакованные байты;
  12+ 5AAA              ;   DEHR_EXTENDED_COMMAND       — длинные команды и терминатор;
  13+ 5AAA              ;   DEHR_APPEND_LAST_6_BYTES    — дописать сохранённый хвост;
  14+ 5AAA              ;   DEHR_REFILL_16_BITS         — пополнить 16-битный битовый резервуар.
  15+ 5AAA              ;
  16+ 5AAA              ; Вход:
  17+ 5AAA              ;   HL — начало упакованного блока с сигнатурой "HR";
  18+ 5AAA              ;   DE — начало области результата (DOS_SWP передаёт #3800).
  19+ 5AAA              ; Выход:
  20+ 5AAA              ;   распакованный драйвер записан начиная с исходного DE;
  21+ 5AAA              ;   отдельного кода состояния нет.
  22+ 5AAA              ; Разрушаются:
  23+ 5AAA              ;   AF, BC, DE, HL, альтернативный набор регистров и IX.
  24+ 5AAA              ;
  25+ 5AAA              ; Формат блока, доказанный кодом ниже и четырьмя встроенными драйверами:
  26+ 5AAA              ;   +0..+1  48 52, сигнатура "HR";
  27+ 5AAA              ;   +2..+3  размер результата, little-endian;
  28+ 5AAA              ;   +4..+5  полный размер упакованного блока, little-endian;
  29+ 5AAA              ;   +6..+11 последние шесть байт результата;
  30+ 5AAA              ;   +12..   поток команд и литералов.
  31+ 5AAA              ; Сигнатура "HR" самой процедурой не проверяется: первые два байта просто
  32+ 5AAA              ; пропускаются. Контрольной суммы, проверки границ и кода ошибки нет;
  33+ 5AAA              ; вызывающая сторона обязана передать корректные размеры и поток с терминатором.
  34+ 5AAA              ;
  35+ 5AAA              ; Физически процедура лежит в boot.$C по #DAB6, но после установки WildDOS
  36+ 5AAA              ; исполняется по #5AAA. Поэтому BOOT_DISASM.ASM включает этот исходник внутри
  37+ 5AAA              ; DISP #5AAA: абсолютные CALL должны вычисляться относительно рабочего адреса.
  38+ 5AAA              DEHR_UNPACK_DRIVER:
  39+ 5AAA D5           DEHRUST PUSH DE            ; Сохранить адрес начала результата.
  40+ 5AAB E5                   PUSH HL
  41+ 5AAC 23                   INC HL
  42+ 5AAD 23                   INC HL
  43+ 5AAE 4E                   LD C,(HL)          ; BC = размер распакованного результата (+2).
  44+ 5AAF 23                   INC HL
  45+ 5AB0 46                   LD B,(HL)
  46+ 5AB1 23                   INC HL
  47+ 5AB2 0B                   DEC BC
  48+ 5AB3 EB                   EX DE,HL
  49+ 5AB4 09                   ADD HL,BC          ; DE = адрес последнего байта результата.
  50+ 5AB5 EB                   EX DE,HL
  51+ 5AB6 4E                   LD C,(HL)          ; BC = полный размер упакованного блока (+4).
  52+ 5AB7 23                   INC HL
  53+ 5AB8 46                   LD B,(HL)
  54+ 5AB9 0B                   DEC BC
  55+ 5ABA E1                   POP HL
  56+ 5ABB 09                   ADD HL,BC          ; HL = последний байт упакованного блока.
  57+ 5ABC ED 52                SBC HL,DE
  58+ 5ABE 19                   ADD HL,DE
  59+ 5ABF 38 02                JR C,LL4019
  60+ 5AC1 54                   LD D,H
  61+ 5AC2 5D                   LD E,L
  62+ 5AC3              ; Если вход пересекается с будущим результатом, поток переносится с конца.
  63+ 5AC3              ; Направление LDDR не позволяет ещё не прочитанным байтам быть затёртыми.
  64+ 5AC3              DEHR_MOVE_OVERLAPPED_STREAM:
  65+ 5AC3 ED B8        LL4019  LDDR
  66+ 5AC5 EB                   EX DE,HL
  67+ 5AC6 D1                   POP DE
  68+ 5AC7 0E 0C                LD C,#0C           ; Пропустить 12-байтовую служебную часть.
  69+ 5AC9 09                   ADD HL,BC
  70+ 5ACA E5                   PUSH HL
  71+ 5ACB DD E1                POP IX             ; IX указывает на первый байт потока.
  72+ 5ACD 3E 03                LD A,#03
  73+ 5ACF              ; Три слова из +6..+11 временно сохраняются на стеке. При завершении они
  74+ 5ACF              ; дописываются как последние шесть байт результата.
  75+ 5ACF              DEHR_SAVE_LAST_6_BYTES:
  76+ 5ACF 2B           LL4025  DEC HL
